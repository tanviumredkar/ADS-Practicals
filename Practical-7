#include <stdio.h>
#include <string.h>

int main() {
    FILE *file;
    char guestList[1000];
    char name[100];
    int found = 0;

    printf("Enter guest name to search: ");
    fgets(name, sizeof(name), stdin);

    name[strcspn(name, "\n")] = 0;

    file = fopen("guestlist.txt", "r");

    if (file == NULL) {
        printf("Error opening file.\n");
        return 1;
    }

    while (fgets(guestList, sizeof(guestList), file)) {

        guestList[strcspn(guestList, "\n")] = 0;

        if (strstr(guestList, name) != NULL) {
            found = 1;
            break;
        }
    }

    fclose(file);

    if (found)
        printf("Guest Found\n");
    else
        printf("Guest Not Found\n");

    return 0;
}
