#include <stdio.h>
#define MAX 50

int adj[MAX][MAX];
int indegree[MAX];

void topological_sort(int n)
{
    int queue[MAX], front = 0, rear = 0;
    int count = 0;

    for(int i = 1; i <= n; i++) {
        if(indegree[i] == 0) {
            queue[rear++] = i;
        }
    }
    printf("\nValid Course Order: ");
    while(front < rear) {
        int course = queue[front++];
        printf("C%d ", course);
        count++;

        for(int j = 1; j <= n; j++) {
            if(adj[course][j] == 1) {
                indegree[j]--;
                if(indegree[j] == 0) {
                    queue[rear++] = j;
                }
            }
        }
    }

    if(count != n) {
        printf("\nCycle detected! No valid course order possible.\n");
    }
}

int main()
{
    int n;

    printf("Enter number of courses: ");
    scanf("%d", &n);

    for(int i = 1; i <= n; i++)
    {
        indegree[i] = 0;
        for(int j = 1; j <= n; j++)
        {
            adj[i][j] = 0;
        }
    }

    printf("Enter adjacency matrix (%d x %d):\n", n, n);
    for(int i = 1; i <= n; i++)
    {
        for(int j = 1; j <= n; j++)
        {
            scanf("%d", &adj[i][j]);

            if(adj[i][j] == 1)
            {
                indegree[j]++;
            }
        }
    }

    topological_sort(n);
    return 0;
}
